    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="220dp"
        android:startColor="#3DFFFFFF"
        android:centerColor="#1FFFFFFF"
        android:endColor="#00FFFFFF" />
</shape>
