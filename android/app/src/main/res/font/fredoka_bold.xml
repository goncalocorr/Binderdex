<?xml version="1.0" encoding="utf-8"?>
<!-- Família de fonte que fixa o peso Bold (700) da Fredoka variável.
     fontVariationSettings é suportado a partir da API 26 (o nosso minSdk). -->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
    <font
        android:font="@font/fredoka_variable"
        android:fontWeight="700"
        android:fontStyle="normal"
        android:fontVariationSettings="'wght' 700" />
</font-family>
