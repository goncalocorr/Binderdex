rules_version = '2';

// Binderdex — regras fechadas por omissão.
// Cada utilizador só pode ler/escrever a SUA própria coleção de cartas.
service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil do utilizador (nome, avatar).
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // Coleção de cartas do utilizador.
      match /cards/{cardId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Tudo o resto é negado por omissão.
  }
}
