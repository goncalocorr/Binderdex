rules_version = '2';

// Binderdex — regras fechadas por omissão.
service cloud.firestore {
  match /databases/{database}/documents {

    // Conta de administração (vê denúncias/sugestões, avisa/bane).
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == 'hivecode.comercial@gmail.com';
    }

    // O próprio utilizador NÃO está banido (bloqueia publicar/contactar).
    function notBanned() {
      let u = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(u) || get(u).data.get('banned', false) != true;
    }

    // O próprio utilizador é premium (marketTier >= 1). Client-trusted (igual
    // aos slots) até haver Play Billing real.
    function isPremium() {
      let u = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(u) && get(u).data.get('marketTier', 0) >= 1;
    }

    // Perfil do utilizador — o dono lê/escreve; o admin também (avisar/banir).
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId)
                         || isAdmin();

      // Coleção de cartas do utilizador.
      match /cards/{cardId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      // Utilizadores bloqueados por este user.
      match /blocks/{blockedUid} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Marketplace público — leitura por autenticados; escrita só do dono (não banido).
    match /listings/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && notBanned()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.mode in ['trade','sell','both']
        && request.resource.data.condition in ['mint','good','used','damaged']
        && (!('wantText' in request.resource.data)
            || request.resource.data.wantText.size() <= 280)
        && (!('note' in request.resource.data)
            || request.resource.data.note.size() <= 280);
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      // Apagar: o dono ou o admin (moderação).
      allow delete: if isAdmin() || (request.auth != null
        && resource.data.ownerUid == request.auth.uid);
    }

    // Anúncios globais — todos leem; só o admin escreve.
    match /broadcasts/{id} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // Denúncias — qualquer autenticado cria; só o admin lê/trata.
    match /reports/{id} {
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // Sugestões — só premium criam; só o admin lê.
    match /suggestions/{id} {
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500
        && isPremium();
      allow read, update, delete: if isAdmin();
    }

    // Apelações — qualquer autenticado cria (mesmo banido!); só o admin lê.
    match /appeals/{id} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000;
      allow read, update, delete: if isAdmin();
    }

    // Conversas privadas — os participantes; o admin lê (diagnóstico de denúncias).
    match /conversations/{cid} {
      allow read: if isAdmin() || (request.auth != null
                  && request.auth.uid in resource.data.participants);
      allow create: if request.auth != null
                    && notBanned()
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      match /messages/{mid} {
        allow read: if isAdmin() || (request.auth != null
          && exists(/databases/$(database)/documents/conversations/$(cid))
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(cid)).data.participants);
        allow create: if request.auth != null
          && notBanned()
          && request.resource.data.senderUid == request.auth.uid
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(cid)).data.participants;
      }
    }

    // Tudo o resto é negado por omissão.
  }
}
